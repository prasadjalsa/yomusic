# Supabase — get these from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role — server-only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# YouTube Data API v3 — get from Google Cloud Console → Credentials
# server-only, NEVER prefix with NEXT_PUBLIC_
YOUTUBE_API_KEY=your-youtube-api-key

# App URL — for OAuth redirect URI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: soft quota cap per user per day (YouTube API units)
DAILY_QUOTA_PER_USER=2000
